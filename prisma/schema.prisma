// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ORGANIZER
  VENDOR
  ADMIN
}

enum TicketStatus {
  VALID
  USED
  CANCELLED
}

enum PurchaseType {
  ONLINE
  GATE
}

enum RecurrencePattern {
  NONE
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum SupportTicketCategory {
  GENERAL
  BILLING
  TICKETS
  HOSTING
  TECHNICAL
  OTHER
}

model User {
  id             Int      @id @default(autoincrement())
  email          String   @unique
  password       String?
  authProvider   String   @default("local")
  authProviderId String?  @unique
  firstName      String
  lastName       String
  phone          String?
  role           UserRole @default(USER)
  isVerified     Boolean  @default(false)
  isGuest        Boolean  @default(false)
  avatar         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  ownedOrganizations     Organization[]           @relation("OwnedOrganizations")
  memberOrganizations    OrganizationMember[]
  followedOrganizations  UserOrganizationFollow[]
  tickets                Ticket[]
  vendorProfiles         Vendor[] // Vendor profiles this user owns
  vendorApplicationsMade VendorApplication[]      @relation("VendorApplicationsMade") // Applications this user has made
  orders                 Order[]
  gatePinsCreated        GatePin[]                @relation("GatePinsCreated")
  errorLogs              ErrorLog[]               @relation("ErrorLogs")
  supportTickets         SupportTicket[]
  supportMessages        SupportTicketMessage[]
}

model Organization {
  id              Int       @id @default(autoincrement())
  name            String
  description     String?
  logo            String?
  website         String?
  socials         String?
  ownerId         Int // Foreign key to User (owner)
  isVerified      Boolean   @default(false)
  rejectionReason String?   @db.Text
  rejectedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Payout Settings
  payoutBankName      String?
  payoutAccountNumber String?
  payoutAccountName   String?
  payoutSchedule      String? @default("AFTER_EVENT")

  // Tax Settings
  taxId           String?
  vatNumber       String?
  businessAddress String? @db.Text

  // Relations
  owner     User                     @relation("OwnedOrganizations", fields: [ownerId], references: [id])
  members   OrganizationMember[]
  followers UserOrganizationFollow[]
  events    Event[]
  gatePins  GatePin[]
  payouts   Payout[]
}

model OrganizationMember {
  id             Int      @id @default(autoincrement())
  userId         Int
  organizationId Int
  role           String   @default("member") // member, admin, etc.
  joinedAt       DateTime @default(now())

  // Relations
  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([userId, organizationId])
}

model UserOrganizationFollow {
  id             Int      @id @default(autoincrement())
  userId         Int
  organizationId Int
  followedAt     DateTime @default(now())

  // Relations
  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([userId, organizationId])
}

model Event {
  id             Int      @id @default(autoincrement())
  slug           String?  @unique
  title          String
  description    String
  startDate      DateTime
  endDate        DateTime
  location       String? // Physical location if applicable
  onlineUrl      String? // URL for online events
  locationType   String // 'physical', 'online', or 'hybrid'
  organizationId Int? // Foreign key to Organization (nullable for transition)
  price          Float?
  capacity       Int?
  imageUrl       String?
  category       String?
  amenities      String?  @db.Text // JSON array of strings
  highlights     String?  @db.Text // JSON array of { icon, label }
  isPublished    Boolean  @default(false)
  latitude       Float? // GPS latitude for event location
  longitude      Float? // GPS longitude for event location
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Recurring event fields
  isRecurring        Boolean            @default(false)
  recurrencePattern  RecurrencePattern? // If recurring, how often
  recurrenceEnd      DateTime? // When recurring ends
  recurrenceInterval Int? // How often to repeat (e.g. every N weeks)

  // Tags
  tags Json? // JSON array of strings

  // Ticket types
  ticketTypes TicketType[]

  // Vendors
  allowVendors       Boolean             @default(false)
  vendorDeadline     DateTime?
  gateTicketing      Boolean             @default(false) // Allow gate ticketing
  vendorTypes        VendorType[] // Support multiple vendor types per event
  vendorApplications VendorApplication[]

  // Relations
  organization Organization? @relation(fields: [organizationId], references: [id])
  tickets      Ticket[]
  orders       Order[]

  @@index([isPublished, startDate])
  @@index([category])
}

// Order model to replace redundant TicketPurchase
model Order {
  id            Int           @id @default(autoincrement())
  userId        Int // User who made the order
  eventId       Int
  totalAmount   Float         @default(0)
  platformFee   Float         @default(0)
  processingFee Float         @default(0)
  netAmount     Float         @default(0)
  status        PaymentStatus @default(PENDING)
  purchaseType  PurchaseType  @default(ONLINE)
  createdAt     DateTime      @default(now())

  // Relations
  user    User     @relation(fields: [userId], references: [id])
  event   Event    @relation(fields: [eventId], references: [id])
  tickets Ticket[]
}

model Payout {
  id             Int           @id @default(autoincrement())
  organizationId Int
  amount         Float
  status         PaymentStatus @default(PENDING)
  reference      String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
}

// Vendor profiles model (for storing vendor information for easy application)
model Vendor {
  id           Int      @id @default(autoincrement())
  userId       Int // The user who owns this vendor profile
  businessName String
  description  String?
  contactEmail String
  contactPhone String?
  website      String?
  logo         String?
  category     String? // e.g., "Food", "Merchandise", "Services"
  isVerified   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  user         User                @relation(fields: [userId], references: [id])
  applications VendorApplication[]
}

// Vendor applications model (for managing vendor applications to events)
model VendorApplication {
  id                Int               @id @default(autoincrement())
  vendorId          Int // The vendor profile applying
  userId            Int // The user who made the application
  eventId           Int
  vendorTypeId      Int? // Reference to the specific vendor type (nullable for backward compatibility during migration)
  applicationStatus ApplicationStatus @default(PENDING)
  paymentAmount     Float?
  paymentStatus     PaymentStatus     @default(PENDING)
  appliedAt         DateTime          @default(now())
  approvedAt        DateTime?
  rejectedAt        DateTime?

  // Relations
  vendor     Vendor      @relation(fields: [vendorId], references: [id])
  user       User        @relation("VendorApplicationsMade", fields: [userId], references: [id])
  event      Event       @relation(fields: [eventId], references: [id])
  vendorType VendorType? @relation(fields: [vendorTypeId], references: [id]) // Relation to vendor type

  @@unique([vendorId, eventId])
}

model TicketType {
  id             Int      @id @default(autoincrement())
  name           String // e.g. "General", "VIP", "Early Bird"
  price          Float
  quantity       Int?
  eventId        Int // Foreign key to Event
  ticketStyle    String   @default("rose") // Visual preset: rose, gold, emerald, purple, midnight, ocean
  accentColor    String? // Optional custom hex override for the ticket stub
  badgeText      String? // Custom label on the ticket stub (defaults to ticket name)
  ticketHeadline String? // e.g. "COME AND JOIN"
  venueLabel     String? // e.g. "LIVE AT"
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  event   Event    @relation(fields: [eventId], references: [id])
  tickets Ticket[]
}

model Ticket {
  id           Int          @id @default(autoincrement())
  eventId      Int
  userId       Int?
  ticketTypeId Int // Foreign key to TicketType
  qrCode       String // Unique QR code for the ticket
  status       TicketStatus @default(VALID)
  purchaseType PurchaseType @default(ONLINE)
  orderId      Int? // Optional link to the order transaction
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  // Relations
  event      Event      @relation(fields: [eventId], references: [id])
  user       User?      @relation(fields: [userId], references: [id])
  ticketType TicketType @relation(fields: [ticketTypeId], references: [id])
  order      Order?     @relation(fields: [orderId], references: [id])
}

// Model for different vendor types within an event
model VendorType {
  id         Int      @id @default(autoincrement())
  name       String // e.g. "Food", "Merchandise", "Services"
  fee        Float? // Fee for this type of vendor (null means free)
  maxVendors Int? // Maximum number of vendors for this type
  eventId    Int // Foreign key to Event
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  event        Event               @relation(fields: [eventId], references: [id])
  applications VendorApplication[]
}

// Gate scanner PINs — lets gate staff scan tickets without a full account
model GatePin {
  id             Int      @id @default(autoincrement())
  pin            String // 6-digit numeric PIN
  staffName      String // Display name for the gate worker
  organizationId Int // Which organisation issued this PIN
  createdById    Int // Organiser user who created it
  createdAt      DateTime @default(now())

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id])
  createdBy    User         @relation("GatePinsCreated", fields: [createdById], references: [id])

  @@unique([pin, organizationId]) // PINs unique per org
  @@index([organizationId])
}

// Error logs — tracks frontend crashes and errors
model ErrorLog {
  id        Int      @id @default(autoincrement())
  message   String // Error message
  stack     String?  @db.Text // Full stack trace
  type      String   @default("ERROR") // ERROR, WARNING, etc.
  severity  String   @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  userId    Int? // User ID if logged in (nullable for anonymous errors)
  userAgent String? // Browser info
  url       String? // Page URL where error occurred
  context   Json? // Additional context (component, action, etc.)
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user User? @relation("ErrorLogs", fields: [userId], references: [id])

  @@index([createdAt])
  @@index([resolved])
}

model SupportTicket {
  id           Int                   @id @default(autoincrement())
  userId       Int?
  contactName  String?
  contactEmail String
  subject      String
  category     SupportTicketCategory @default(GENERAL)
  status       SupportTicketStatus   @default(OPEN)
  priority     String                @default("normal")
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  user     User?                  @relation(fields: [userId], references: [id])
  messages SupportTicketMessage[]

  @@index([status])
  @@index([userId])
}

model SupportTicketMessage {
  id         Int      @id @default(autoincrement())
  ticketId   Int
  authorId   Int?
  authorRole String   @default("USER")
  body       String   @db.Text
  createdAt  DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author User?         @relation(fields: [authorId], references: [id])

  @@index([ticketId])
}

model Otp {
  id        Int      @id @default(autoincrement())
  contact   String // Email or phone number
  code      String // 6-digit OTP code
  attempts  Int      @default(0) // Failed verification attempts
  verified  Boolean  @default(false) // Whether OTP has been verified
  expiresAt DateTime // When the OTP expires
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([contact]) // Only one active OTP per contact
  @@index([contact])
  @@index([expiresAt])
}
