{
  "name": "eventify-backend",
  "version": "1.0.0",
  "description": "Backend for Eventify event ticketing platform",
  "main": "dist/index.js",
  "engines": {
    "node": "18.x"
  },
  "scripts": {
    "dev": "nodemon src/index.ts",
    "build": "tsc",
    "vercel-build": "node scripts/set-prisma-provider.js && npx prisma generate && tsc",
    "start": "node dist/index.js",
    "db:generate": "node scripts/set-prisma-provider.js && npx prisma generate",
    "db:migrate": "node scripts/set-prisma-provider.js && npx prisma migrate dev",
    "db:push": "node scripts/set-prisma-provider.js && npx prisma db push",
    "db:studio": "node scripts/set-prisma-provider.js && npx prisma studio",
    "seed": "ts-node seeds/seed.ts",
    "postinstall": "node scripts/set-prisma-provider.js && npx prisma generate"
  },
  "keywords": [
    "event",
    "ticketing",
    "platform"
  ],
  "author": "Eventify",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^4.16.2",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.7",
    "qrcode": "^1.5.3",
    "socket.io": "^4.7.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.4",
    "@types/express": "^4.17.18",
    "@types/jsonwebtoken": "^9.0.3",
    "@types/multer": "^1.4.8",
    "@types/node": "^20.8.2",
    "@types/nodemailer": "^6.4.11",
    "@types/qrcode": "^1.5.2",
    "nodemon": "^3.0.1",
    "prisma": "^4.16.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.2.2"
  }
}
